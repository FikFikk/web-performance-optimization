{
  "name": "javascript-code-splitting-examples",
  "version": "1.0.0",
  "description": "Code splitting dan lazy loading implementation examples",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:analyze": "webpack --mode production --env analyze",
    "measure": "node measure-bundle-size.js",
    "lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html --preset=desktop"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.0",
    "web-vitals": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.2",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0",
    "webpack-bundle-analyzer": "^4.9.0",
    "html-webpack-plugin": "^5.5.3",
    "css-loader": "^6.8.0",
    "style-loader": "^3.3.3",
    "compression-webpack-plugin": "^10.0.0",
    "lighthouse": "^10.4.0",
    "bundlesize": "^0.18.1"
  },
  "bundlesize": [
    {
      "path": "./dist/main.*.js",
      "maxSize": "50 KB",
      "compression": "gzip"
    },
    {
      "path": "./dist/vendors.*.js",
      "maxSize": "180 KB",
      "compression": "gzip"
    },
    {
      "path": "./dist/*.chunk.js",
      "maxSize": "100 KB",
      "compression": "gzip"
    }
  ]
}
